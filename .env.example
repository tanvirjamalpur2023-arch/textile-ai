# For Vercel deployment, set these environment variables in Vercel Dashboard

# Option 1: OpenAI API (recommended for Vercel)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# Option 2: Any OpenAI-compatible API (e.g., DeepSeek, Together AI, etc.)
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# Database (optional - only needed if using Prisma)
DATABASE_URL=file:./db/custom.db
